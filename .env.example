# ============================================================
# ЦПР Партнёр — переменные окружения для self-hosting (VPS)
# Скопируй в .env и заполни своими значениями
# ============================================================

# --- Клиентские (попадают в браузер, префикс VITE_) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...   # publishable / anon key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# --- Серверные (только для SSR/server functions, НИКОГДА не коммить) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...        # обязателен для админ-операций
SUPABASE_PROJECT_ID=your-project-ref

# --- Опциональные интеграции ---
FIRECRAWL_API_KEY=                              # для парсинга, можно пусто
LOVABLE_API_KEY=                                # AI Gateway, если используешь

# --- Уведомления о заявках ---
NOTIFICATIONS_ENABLED=true

# Telegram через Cloudflare Worker proxy.
# Если proxy проксирует Telegram Bot API, заполни TG_BOT_TOKEN и TG_CHAT_ID.
# Запрос уйдёт на: https://tg-proxy.parsikovevgenij470.workers.dev/bot<TOKEN>/sendMessage
TG_NOTIFICATIONS_ENABLED=true
TG_PROXY_URL=https://tg-proxy.parsikovevgenij470.workers.dev
TG_BOT_TOKEN=
TG_CHAT_ID=
TG_PROXY_SECRET=

# Email через Nodemailer / SMTP.
MAIL_NOTIFICATIONS_ENABLED=true
MAIL_TO=info@cpr-partner.ru
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ЦПР Партнер <no-reply@cpr-partner.ru>"

# --- Прод ---
NODE_ENV=production
PORT=3000
